generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATOR
  MASTER
}

enum ProcessStatus {
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  AGUARDANDO_OPERADOR
  CORRECAO_SOLICITADA
  CONCLUIDO
  CANCELADO
}

enum StepKey {
  ETAPA_1
  ETAPA_2
  ETAPA_3
  ETAPA_4
  ETAPA_5
  ETAPA_6
}

enum KanbanStage {
  VIABILIDADE
  DOC_INICIAL_APROVADA
  DBE_RECEITA_FEDERAL
  PREPARACAO_DOCUMENTOS
  AGUARDANDO_DOCUMENTOS
  ANALISE_JUCEB
  EXIGENCIA_JUCEB
  FINALIZADO
}

enum AlteracaoContratualStage {
  SOLICITACAO_RECEBIDA
  ANALISE_JURIDICA
  AJUSTES_DOCUMENTAIS
  PROTOCOLO
  FINALIZADO
}

enum StepSide {
  CLIENTE
  OPERADOR
}

enum DocumentItemKey {
  IDENTIFICACAO_SOCIOS
  COMPROVANTE_RESIDENCIA
  FOTO_FACHADA
}

enum DocumentItemStatus {
  PENDENTE
  AGUARDANDO_VALIDACAO
  APROVADO
  REPROVADO
}

enum AuditActorRole {
  CLIENTE
  OPERADOR
  MASTER
  SYSTEM
}

enum ChatAuthorRole {
  CLIENTE
  OPERADOR
  BOT
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum SlaStatus {
  ON_TRACK
  AT_RISK
  OVERDUE
  STOPPED
}

enum IdempotencyScope {
  PROCESS_CREATE
  CUSTOMER_LINK_REQUEST
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  whatsapp     String?
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedProcesses Process[]          @relation("ProcessOwner")
  sessions       Session[]
  notifications  UserNotification[]
}

model Process {
  id                 String          @id @default(uuid())
  clientName         String?
  companyKey         String?
  clientEmail        String
  clientPhone        String?
  status             ProcessStatus   @default(EM_ANDAMENTO)
  currentStep        StepKey         @default(ETAPA_1)
  kanbanStage        KanbanStage     @default(VIABILIDADE)
  ownerId            String?
  owner              User?           @relation("ProcessOwner", fields: [ownerId], references: [id])
  cancelledAt        DateTime?
  cancelledByRole    AuditActorRole?
  cancelledById      String?
  cancelReason       String?
  operatorStatusNote String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  steps                 ProcessStep[]
  checklists            Checklist[]
  documents             DocumentItem[]
  chats                 ChatThread[]
  ownerHistory          ProcessOwnerHistory[]
  slaEvents             SlaEvent[]
  reports               Report[]
  notifications         UserNotification[]
  fileObjects           FileObject[]
  alteracoesContratuais AlteracaoContratual[]

  @@index([ownerId, createdAt])
  @@index([kanbanStage, ownerId, createdAt])
  @@index([clientEmail, createdAt])
  @@index([companyKey, createdAt])
  @@index([clientPhone, createdAt])
  @@index([status, createdAt])
}

model AlteracaoContratual {
  id              String                   @id @default(uuid())
  processId       String
  alterationType  String
  stage           AlteracaoContratualStage @default(SOLICITACAO_RECEBIDA)
  version         Int                      @default(1)
  requestedByRole AuditActorRole
  requestedById   String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  process Process                      @relation(fields: [processId], references: [id])
  history AlteracaoContratualHistory[]

  @@unique([processId, alterationType])
  @@index([stage, updatedAt])
  @@index([processId, updatedAt])
}

model AlteracaoContratualHistory {
  id          String                    @id @default(uuid())
  alteracaoId String
  fromStage   AlteracaoContratualStage?
  toStage     AlteracaoContratualStage
  version     Int
  actorRole   AuditActorRole
  actorId     String?
  comment     String?
  createdAt   DateTime                  @default(now())

  alteracao AlteracaoContratual @relation(fields: [alteracaoId], references: [id], onDelete: Cascade)

  @@unique([alteracaoId, version])
  @@index([alteracaoId, createdAt])
}

model ProcessStep {
  id        String        @id @default(uuid())
  processId String
  stepKey   StepKey
  side      StepSide
  data      Json
  status    ProcessStatus
  locked    Boolean       @default(false)
  updatedAt DateTime      @updatedAt
  createdAt DateTime      @default(now())

  process Process @relation(fields: [processId], references: [id])

  @@unique([processId, stepKey])
}

model Checklist {
  id        String   @id @default(uuid())
  processId String
  stepKey   StepKey
  items     Json
  status    String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  process Process @relation(fields: [processId], references: [id])

  @@unique([processId, stepKey])
}

model DocumentItem {
  id        String             @id @default(uuid())
  processId String
  itemKey   DocumentItemKey
  socioId   String?
  status    DocumentItemStatus @default(PENDENTE)
  version   Int                @default(1)
  reason    String?
  updatedAt DateTime           @updatedAt
  createdAt DateTime           @default(now())

  process Process        @relation(fields: [processId], references: [id])
  files   DocumentFile[]

  @@unique([processId, itemKey, socioId])
}

model DocumentFile {
  id             String         @id @default(uuid())
  itemId         String
  fileName       String
  mimeType       String
  size           Int
  data           Bytes
  createdAt      DateTime       @default(now())
  uploadedByRole AuditActorRole
  uploadedById   String?

  item DocumentItem @relation(fields: [itemId], references: [id])

  @@index([itemId, createdAt])
}

model ChatThread {
  id        String    @id @default(uuid())
  processId String
  createdAt DateTime  @default(now())
  botState  Json?
  handoffAt DateTime?

  process  Process       @relation(fields: [processId], references: [id])
  messages ChatMessage[]

  @@unique([processId])
}

model ChatMessage {
  id         String         @id @default(uuid())
  threadId   String
  authorRole ChatAuthorRole
  authorId   String?
  body       String
  createdAt  DateTime       @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id])

  @@index([threadId, createdAt])
}

model Session {
  id             String         @id @default(uuid())
  role           AuditActorRole
  userId         String?
  clientEmail    String?
  clientWhatsapp String?
  tokenHash      String         @unique
  expiresAt      DateTime
  lastActiveAt   DateTime
  rotatedAt      DateTime?
  createdAt      DateTime       @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([expiresAt])
}

model CustomerLinkToken {
  id                String    @id @default(uuid())
  email             String?
  whatsapp          String?
  tokenHash         String    @unique
  tokenExpiresAt    DateTime
  otpHash           String?
  otpExpiresAt      DateTime?
  otpSentCount      Int       @default(0)
  otpFailedAttempts Int       @default(0)
  otpBlockedUntil   DateTime?
  lastOtpSentAt     DateTime?
  usedAt            DateTime?
  createdAt         DateTime  @default(now())

  @@index([email, usedAt, tokenExpiresAt, createdAt(sort: Desc)])
  @@index([whatsapp, usedAt, tokenExpiresAt, createdAt(sort: Desc)])
}

model ProcessOwnerHistory {
  id         String   @id @default(uuid())
  processId  String
  ownerId    String?
  assignedAt DateTime @default(now())
  assignedBy String?

  process Process @relation(fields: [processId], references: [id])

  @@index([ownerId, assignedAt])
  @@index([processId, assignedAt])
}

model AuditEvent {
  id         String         @id @default(uuid())
  actorRole  AuditActorRole
  actorId    String?
  actorEmail String?
  action     String
  entity     String
  entityId   String?
  metadata   Json
  ip         String?
  userAgent  String?
  createdAt  DateTime       @default(now())

  @@index([createdAt(sort: Desc), entity, action])
}

model SlaConfigStep {
  id            String   @id @default(uuid())
  stepKey       StepKey
  side          StepSide
  durationHours Int
  alertPercent  Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([stepKey, side])
}

model SlaEvent {
  id             String    @id @default(uuid())
  processId      String
  stepKey        StepKey
  side           StepSide
  startedAt      DateTime
  dueAt          DateTime
  status         SlaStatus
  lastNotifiedAt DateTime?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  process Process @relation(fields: [processId], references: [id])

  @@unique([processId, stepKey, side])
  @@index([status, dueAt])
}

model Report {
  id        String   @id @default(uuid())
  processId String
  fileName  String
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())

  process Process @relation(fields: [processId], references: [id])

  @@index([processId, createdAt(sort: Desc)])
}

model Notification {
  id        String              @id @default(uuid())
  channel   NotificationChannel
  recipient String
  subject   String
  body      String
  status    String
  createdAt DateTime            @default(now())

  @@index([createdAt(sort: Desc), channel, status])
}

model UserNotification {
  id        String    @id @default(uuid())
  userId    String
  processId String?
  type      String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id])
  process Process? @relation(fields: [processId], references: [id])

  @@index([userId, readAt])
}

model IdempotencyKey {
  id          String           @id @default(uuid())
  scope       IdempotencyScope
  key         String
  requestHash String
  response    Json?
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([scope, key])
  @@index([expiresAt])
}

model FileObject {
  id           String   @id @default(uuid())
  processId    String?
  bucket       String
  objectKey    String   @unique
  originalName String
  mimeType     String
  sizeBytes    Int
  sha256       String
  uploadedAt   DateTime @default(now())

  process Process? @relation(fields: [processId], references: [id])
}
